        "measures": [
          {
            "name": "Nb Absences",
            "expression": "COUNTROWS('gold Fact_Absences')"
          },
          {
            "name": "Total Jours Absence",
            "expression": "SUM('gold Fact_Absences'[nb_jours])"
          },
          {
            "name": "Taux Absenteisme %",
            "expression": "DIVIDE([Total Jours Absence],220 * 200)",
            "formatString": "0.00 %;-0.00 %;0.00 %"
          },
          {
            "name": "Moy Jours Absence",
            "expression": "AVERAGE('gold Fact_Absences'[nb_jours])"
          }
